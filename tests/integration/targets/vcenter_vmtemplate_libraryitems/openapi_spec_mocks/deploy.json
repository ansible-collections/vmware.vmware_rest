{
  "openapi": "3.0.3",
  "info": {
    "title": "vCenter VM Template Library Items Mock",
    "version": "9.1.0.0"
  },
  "servers": [
    {
      "url": "https://{host}/api",
      "variables": {
        "host": {
          "default": "localhost"
        }
      }
    }
  ],
  "paths": {
    "/vcenter/vm-template/library-items/{templateLibraryItem}?action=deploy": {
      "post": {
        "operationId": "Vcenter.VmTemplate.LibraryItems_deploy",
        "parameters": [
          {
            "name": "templateLibraryItem",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "ok",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                },
                "example": "vm-1001"
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {}
  }
}
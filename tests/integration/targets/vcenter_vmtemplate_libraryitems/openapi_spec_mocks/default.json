{
  "openapi": "3.0.3",
  "info": {
    "title": "vCenter VM Template Library Items Mock",
    "version": "9.1.0.0"
  },
  "servers": [
    {
      "url": "https://{host}/api",
      "variables": {
        "host": {
          "default": "localhost"
        }
      }
    }
  ],
  "paths": {
    "/vcenter/vm-template/library-items": {
      "post": {
        "operationId": "Vcenter.VmTemplate.LibraryItems_create",
        "parameters": [],
        "responses": {
          "200": {
            "description": "ok",
            "content": {
              "application/json": {
                "schema": {"type": "string"},
                "example": "tmpl-lib-item-1"
              }
            }
          }
        }
      }
    },
    "/vcenter/vm-template/library-items/{templateLibraryItem}": {
      "get": {
        "operationId": "Vcenter.VmTemplate.LibraryItems_get",
        "parameters": [
          {"name": "templateLibraryItem", "in": "path", "required": true, "schema": {"type": "string"}}
        ],
        "responses": {
          "200": {
            "description": "ok",
            "content": {
              "application/json": {
                "schema": {"type": "object"},
                "example": {"name": "my-template", "library": "fbcc0f38-b7d9-4243-95f6-fb28f1ab35a6"}
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {}
  }
}
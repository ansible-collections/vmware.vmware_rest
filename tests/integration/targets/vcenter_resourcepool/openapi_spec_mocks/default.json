{
  "openapi": "3.0.3",
  "info": {
    "title": "vCenter Resource Pool Mock",
    "version": "9.1.0"
  },
  "servers": [
    {
      "url": "https://localhost:1080/api"
    }
  ],
  "paths": {
    "/vcenter/resource-pool": {
      "get": {
        "operationId": "list",
        "summary": "List resource pools",
        "responses": {
          "200": {
            "description": "List of resource pools",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/ResourcePoolSummary"
                  }
                },
                "examples": {
                  "empty": {
                    "value": []
                  },
                  "with_pools": {
                    "value": [
                      {
                        "resource_pool": "resgroup-1009",
                        "name": "my_resource_pool"
                      }
                    ]
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "create",
        "summary": "Create resource pool",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ResourcePoolCreateSpec"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Resource pool created",
            "content": {
              "application/json": {
                "schema": {
                  "type": "string"
                },
                "example": "resgroup-1009"
              }
            }
          }
        }
      }
    },
    "/vcenter/resource-pool/{resourcePool}": {
      "get": {
        "operationId": "get",
        "summary": "Get resource pool details",
        "parameters": [
          {
            "name": "resourcePool",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Resource pool details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ResourcePoolInfo"
                },
                "example": {
                  "name": "my_resource_pool",
                  "resource_pools": [],
                  "cpu_allocation": {
                    "reservation": 1000,
                    "expandable_reservation": true,
                    "limit": 4000,
                    "shares": {
                      "level": "NORMAL"
                    }
                  },
                  "memory_allocation": {
                    "reservation": 1024,
                    "expandable_reservation": true,
                    "limit": 4096,
                    "shares": {
                      "level": "NORMAL"
                    }
                  }
                }
              }
            }
          },
          "404": {
            "description": "Resource pool not found"
          }
        }
      },
      "patch": {
        "operationId": "update",
        "summary": "Update resource pool",
        "parameters": [
          {
            "name": "resourcePool",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ResourcePoolUpdateSpec"
              }
            }
          }
        },
        "responses": {
          "204": {
            "description": "Resource pool updated"
          }
        }
      },
      "delete": {
        "operationId": "delete",
        "summary": "Delete resource pool",
        "parameters": [
          {
            "name": "resourcePool",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Resource pool deleted"
          },
          "404": {
            "description": "Resource pool not found"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ResourcePoolSummary": {
        "type": "object",
        "required": ["resource_pool", "name"],
        "properties": {
          "resource_pool": {
            "type": "string"
          },
          "name": {
            "type": "string"
          }
        }
      },
      "ResourcePoolInfo": {
        "type": "object",
        "required": ["name", "resource_pools"],
        "properties": {
          "name": {
            "type": "string"
          },
          "resource_pools": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "cpu_allocation": {
            "$ref": "#/components/schemas/ResourceAllocationInfo"
          },
          "memory_allocation": {
            "$ref": "#/components/schemas/ResourceAllocationInfo"
          }
        }
      },
      "ResourceAllocationInfo": {
        "type": "object",
        "required": ["reservation", "expandable_reservation", "limit", "shares"],
        "properties": {
          "reservation": {
            "type": "integer",
            "format": "int64"
          },
          "expandable_reservation": {
            "type": "boolean"
          },
          "limit": {
            "type": "integer",
            "format": "int64"
          },
          "shares": {
            "$ref": "#/components/schemas/SharesInfo"
          }
        }
      },
      "SharesInfo": {
        "type": "object",
        "required": ["level"],
        "properties": {
          "level": {
            "type": "string",
            "enum": ["LOW", "NORMAL", "HIGH", "CUSTOM"]
          },
          "shares": {
            "type": "integer",
            "format": "int64"
          }
        }
      },
      "ResourcePoolCreateSpec": {
        "type": "object",
        "required": ["name", "parent"],
        "properties": {
          "name": {
            "type": "string"
          },
          "parent": {
            "type": "string"
          },
          "cpu_allocation": {
            "$ref": "#/components/schemas/ResourceAllocationCreateSpec"
          },
          "memory_allocation": {
            "$ref": "#/components/schemas/ResourceAllocationCreateSpec"
          }
        }
      },
      "ResourceAllocationCreateSpec": {
        "type": "object",
        "properties": {
          "reservation": {
            "type": "integer",
            "format": "int64"
          },
          "expandable_reservation": {
            "type": "boolean"
          },
          "limit": {
            "type": "integer",
            "format": "int64"
          },
          "shares": {
            "$ref": "#/components/schemas/SharesInfo"
          }
        }
      },
      "ResourcePoolUpdateSpec": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "cpu_allocation": {
            "$ref": "#/components/schemas/ResourceAllocationUpdateSpec"
          },
          "memory_allocation": {
            "$ref": "#/components/schemas/ResourceAllocationUpdateSpec"
          }
        }
      },
      "ResourceAllocationUpdateSpec": {
        "type": "object",
        "properties": {
          "reservation": {
            "type": "integer",
            "format": "int64"
          },
          "expandable_reservation": {
            "type": "boolean"
          },
          "limit": {
            "type": "integer",
            "format": "int64"
          },
          "shares": {
            "$ref": "#/components/schemas/SharesInfo"
          }
        }
      }
    }
  }
}

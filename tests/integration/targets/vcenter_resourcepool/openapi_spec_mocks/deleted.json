{
  "openapi": "3.0.3",
  "info": {
    "title": "vCenter Resource Pool Mock",
    "version": "9.1.0.0"
  },
  "servers": [
    {
      "url": "https://{host}/api",
      "variables": {
        "host": {
          "default": "localhost"
        }
      }
    }
  ],
  "paths": {
    "/vcenter/resource-pool/{resourcePool}": {
      "get": {
        "operationId": "Vcenter.ResourcePool_get",

{
  "openapi": "3.0.3",
  "info": {
    "title": "Appliance Health System Mock",
    "version": "9.1.0.0"
  },
  "servers": [
    {
      "url": "https://{host}/api",
      "variables": {
        "host": {
          "default": "localhost"
        }
      }
    }
  ],
  "paths": {
    "/appliance/health/system": {
      "get": {
        "operationId": "get",
        "responses": {
          "200": {
            "description": "System health",
            "content": {
              "application/json": {
                "schema": {
                  "type": "string"
                },
                "example": "green"
              }
            }
          }
        }
      }
    }
  }
}

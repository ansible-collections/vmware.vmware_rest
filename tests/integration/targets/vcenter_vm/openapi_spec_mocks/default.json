{
  "openapi": "3.0.3",
  "info": {
    "title": "vCenter VM Mock",
    "version": "9.1.0.0"
  },
  "servers": [
    {
      "url": "https://{host}/api",
      "variables": {
        "host": {
          "default": "localhost"
        }
      }
    }
  ],
  "paths": {
    "/vcenter/vm": {
      "get": {
        "operationId": "Vcenter.VM_list",
        "parameters": [],
        "responses": {
          "200": {
            "description": "ok",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                },
                "example": []
              }
            }
          }
        }
      },
      "post": {
        "operationId": "Vcenter.VM_create",
        "parameters": [],
        "responses": {
          "200": {
            "description": "ok",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                },
                "example": "vm-1001"
              }
            }
          }
        }
      }
    },
    "/vcenter/vm/{vm}": {
      "get": {
        "operationId": "Vcenter.VM_get",
        "parameters": [
          {
            "name": "vm",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "ok",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                },
                "example": {
                  "name": "my-vm",
                  "power_state": "POWERED_OFF",
                  "guest_OS": "RHEL_9_64"
                }
              }
            }
          }
        }
      },
      "delete": {
        "operationId": "Vcenter.VM_delete",
        "parameters": [
          {
            "name": "vm",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "ok"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {}
  }
}
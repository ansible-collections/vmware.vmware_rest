{
  "openapi": "3.0.3",
  "info": {
    "title": "vCenter VM Hardware Boot Device Mock",
    "version": "9.1.0.0"
  },
  "servers": [
    {
      "url": "https://{host}/api",
      "variables": {
        "host": {
          "default": "localhost"
        }
      }
    }
  ],
  "paths": {
    "/vcenter/vm/{vm}/hardware/boot/device": {
      "get": {
        "operationId": "Vcenter.Vm.Hardware.Boot.Device_get",
        "parameters": [
          {
            "name": "vm",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "ok",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                },
                "example": [
                  {
                    "type": "DISK",
                    "disks": [
                      "2000"
                    ]
                  }
                ]
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {}
  }
}
{
  "openapi": "3.0.3",
  "info": {
    "title": "vCenter VM Hardware Serial Mock",
    "version": "9.1.0.0"
  },
  "servers": [
    {
      "url": "https://{host}/api",
      "variables": {
        "host": {
          "default": "localhost"
        }
      }
    }
  ],
  "paths": {
    "/vcenter/vm/{vm}/hardware/serial": {
      "get": {
        "operationId": "Vcenter.Vm.Hardware.Serial_list",
        "parameters": [
          {
            "name": "vm",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "ok",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                },
                "example": []
              }
            }
          }
        }
      },
      "post": {
        "operationId": "Vcenter.Vm.Hardware.Serial_create",
        "parameters": [
          {
            "name": "vm",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "ok",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                },
                "example": "com1"
              }
            }
          }
        }
      }
    },
    "/vcenter/vm/{vm}/hardware/serial/{port}": {
      "get": {
        "operationId": "Vcenter.Vm.Hardware.Serial_get",
        "parameters": [
          {
            "name": "vm",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "port",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "ok",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                },
                "example": {
                  "label": "Serial port 1",
                  "type": "SERIAL",
                  "start_connected": false
                }
              }
            }
          }
        }
      },
      "patch": {
        "operationId": "Vcenter.Vm.Hardware.Serial_update",
        "parameters": [
          {
            "name": "vm",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "port",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "ok"
          }
        }
      },
      "delete": {
        "operationId": "Vcenter.Vm.Hardware.Serial_delete",
        "parameters": [
          {
            "name": "vm",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "port",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "ok"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {}
  }
}
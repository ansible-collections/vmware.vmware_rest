{
  "openapi": "3.0.3",
  "info": {
    "title": "vCenter VM Hardware Boot Mock",
    "version": "9.1.0.0"
  },
  "servers": [
    {
      "url": "https://{host}/api",
      "variables": {
        "host": {
          "default": "localhost"
        }
      }
    }
  ],
  "paths": {
    "/vcenter/vm/{vm}/hardware/boot": {
      "get": {
        "operationId": "Vcenter.Vm.Hardware.Boot_get",
        "parameters": [
          {
            "name": "vm",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "ok",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                },
                "example": {
                  "type": "EFI",
                  "delay": 5000,
                  "retry": true
                }
              }
            }
          }
        }
      },
      "patch": {
        "operationId": "Vcenter.Vm.Hardware.Boot_update",
        "parameters": [
          {
            "name": "vm",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "ok"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {}
  }
}
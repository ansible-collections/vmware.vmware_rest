{
  "openapi": "3.0.3",
  "info": {
    "title": "Appliance vMon Service Mock",
    "version": "8.0.2.0"
  },
  "servers": [
    {
      "url": "https://{host}",
      "variables": {
        "host": {
          "default": "localhost"
        }
      }
    }
  ],
  "paths": {
    "/rest/appliance/vmon/service/{service}": {
      "get": {
        "operationId": "get",
        "parameters": [
          {
            "name": "service",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Service info",
            "content": {
              "application/json": {
                "example": {
                  "value": {
                    "name_key": "cis.vpxd.ServiceName",
                    "description_key": "cis.vpxd.ServiceDescription",
                    "startup_type": "MANUAL",
                    "state": "STOPPED"
                  }
                }
              }
            }
          }
        }
      },
      "patch": {
        "operationId": "update",
        "parameters": [
          {
            "name": "service",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Success"
          }
        }
      }
    },
    "/rest/appliance/vmon/service/{service}/start": {
      "post": {
        "operationId": "start",
        "parameters": [
          {
            "name": "service",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Success"
          }
        }
      }
    }
  }
}

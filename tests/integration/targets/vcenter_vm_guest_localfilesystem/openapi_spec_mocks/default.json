{
  "openapi": "3.0.3",
  "info": {
    "title": "vCenter VM Guest Local Filesystem Mock",
    "version": "9.1.0.0"
  },
  "servers": [
    {
      "url": "https://{host}/api",
      "variables": {
        "host": {
          "default": "localhost"
        }
      }
    }
  ],
  "paths": {
    "/vcenter/vm/{vm}/guest/local-filesystem": {
      "get": {
        "operationId": "Vcenter.Vm.Guest.LocalFilesystem_get",
        "parameters": [
          {
            "name": "vm",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "ok",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                },
                "example": [
                  {
                    "filesystem": "/dev/sda1",
                    "mount_point": "/",
                    "capacity": 1000000,
                    "free_space": 500000
                  }
                ]
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {}
  }
}
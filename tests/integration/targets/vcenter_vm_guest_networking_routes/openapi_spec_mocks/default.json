{
  "openapi": "3.0.3",
  "info": {
    "title": "vCenter VM Guest Networking Routes Mock",
    "version": "9.1.0.0"
  },
  "servers": [
    {
      "url": "https://{host}/api",
      "variables": {
        "host": {
          "default": "localhost"
        }
      }
    }
  ],
  "paths": {
    "/vcenter/vm/{vm}/guest/networking/routes": {
      "get": {
        "operationId": "Vcenter.Vm.Guest.Networking.Routes_list",
        "parameters": [
          {
            "name": "vm",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "ok",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                },
                "example": [
                  {
                    "network": "0.0.0.0",
                    "prefix_length": 0,
                    "gateway": {
                      "ip_address": "192.0.2.1"
                    }
                  }
                ]
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {}
  }
}
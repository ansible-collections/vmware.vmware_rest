{
  "openapi": "3.0.3",
  "info": {
    "title": "vCenter VM Hardware Ethernet Mock",
    "version": "9.1.0.0"
  },
  "servers": [
    {
      "url": "https://{host}/api",
      "variables": {
        "host": {
          "default": "localhost"
        }
      }
    }
  ],
  "paths": {
    "/vcenter/vm/{vm}/hardware/ethernet": {
      "get": {
        "operationId": "Vcenter.Vm.Hardware.Ethernet_list",
        "parameters": [
          {
            "name": "vm",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "ok",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                },
                "example": [
                  {
                    "nic": "4000"
                  }
                ]
              }
            }
          }
        }
      }
    },
    "/vcenter/vm/{vm}/hardware/ethernet/{nic}": {
      "get": {
        "operationId": "Vcenter.Vm.Hardware.Ethernet_get",
        "parameters": [
          {
            "name": "vm",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "nic",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "ok",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                },
                "example": {
                  "label": "Network adapter 1",
                  "type": "VMXNET3",
                  "pci_slot_number": 4,
                  "start_connected": true
                }
              }
            }
          }
        }
      },
      "patch": {
        "operationId": "Vcenter.Vm.Hardware.Ethernet_update",
        "parameters": [
          {
            "name": "vm",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "nic",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "ok"
          }
        }
      },
      "delete": {
        "operationId": "Vcenter.Vm.Hardware.Ethernet_delete",
        "parameters": [
          {
            "name": "vm",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "nic",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "ok"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {}
  }
}
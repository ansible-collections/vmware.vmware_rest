{
  "openapi": "3.0.3",
  "info": {
    "title": "vCenter VM Guest Networking Mock",
    "version": "9.1.0.0"
  },
  "servers": [
    {
      "url": "https://{host}/api",
      "variables": {
        "host": {
          "default": "localhost"
        }
      }
    }
  ],
  "paths": {
    "/vcenter/vm/{vm}/guest/networking": {
      "get": {
        "operationId": "Vcenter.Vm.Guest.Networking_get",
        "parameters": [
          {
            "name": "vm",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "ok",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                },
                "example": {
                  "dns": {
                    "ip_addresses": [
                      "192.0.2.1"
                    ],
                    "search_domains": [
                      "example.com"
                    ]
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {}
  }
}
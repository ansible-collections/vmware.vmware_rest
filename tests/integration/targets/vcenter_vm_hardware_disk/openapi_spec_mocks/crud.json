{
  "openapi": "3.0.3",
  "info": {
    "title": "vCenter VM Hardware Disk Mock",
    "version": "9.1.0.0"
  },
  "servers": [
    {
      "url": "https://{host}/api",
      "variables": {
        "host": {
          "default": "localhost"
        }
      }
    }
  ],
  "paths": {
    "/vcenter/vm/{vm}/hardware/disk": {
      "get": {
        "operationId": "Vcenter.Vm.Hardware.Disk_list",
        "parameters": [
          {
            "name": "vm",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "ok",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                },
                "example": []
              }
            }
          }
        }
      },
      "post": {
        "operationId": "Vcenter.Vm.Hardware.Disk_create",
        "parameters": [
          {
            "name": "vm",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "ok",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                },
                "example": "2000"
              }
            }
          }
        }
      }
    },
    "/vcenter/vm/{vm}/hardware/disk/{disk}": {
      "get": {
        "operationId": "Vcenter.Vm.Hardware.Disk_get",
        "parameters": [
          {
            "name": "vm",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "disk",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "ok",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                },
                "example": {
                  "label": "Hard disk 1",
                  "type": "SATA",
                  "capacity": 320000
                }
              }
            }
          }
        }
      },
      "patch": {
        "operationId": "Vcenter.Vm.Hardware.Disk_update",
        "parameters": [
          {
            "name": "vm",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "disk",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "ok"
          }
        }
      },
      "delete": {
        "operationId": "Vcenter.Vm.Hardware.Disk_delete",
        "parameters": [
          {
            "name": "vm",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "disk",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "ok"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {}
  }
}